# ── Ollama (local LLM) ────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── ChromaDB ───────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=.chroma_db
CHROMA_COLLECTION=ercot_grid

# ── RAG ────────────────────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64
TOP_K=5
